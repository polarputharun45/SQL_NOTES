SELECT first_name FROM Customers

-- only select for whole row  

               --LIKE COMMAND--
SELECT first_name FROM Customers
WHERE first_name LIKE 'J%'   -- only first_name starts with J
WHERE first_name LIKE '%j'   -- only first_name ends with J
WHERE first_name LIKE '%J%'  -- name contains atleas one J
WHERE first_name LIKE '_J'   --second letter is J
WHERE first_name LIKE '____' --4 letters word
WHERE first_name LIKE 'S%A'  --word starts with A and end with A
WHERE first_name NOT LIKE '%J%' -- the words does not contain J


               --ORDER BY --

SELECT name FROM Customers
ORDER BY name ASC;     -- to display the names with an asseccending order
ORDER BY name DESC;   -- to display the names with an descending order




            --DISTINCT--


SELECT DISTINCT first_name
from Customers;   -- Removes duplicate names from customers
SELECT COUNT(DISTINCT city)
FROM Customers;   -- after removes it will give the remain customers



              -- AGGREGATE FUNCTIONs-

SELECT COUNT(*) FROM Customers -- it tell how many coustomers are present in the list 
SELECT SUM(bill) FROM Customers -- it calculates all customers bill 
-- for both we can add features like where the city of chennai candidates
--- it will applicable for both like 
--  in customers how many members from chennai 
--  in customers how much bill was payed from chennai 
SELECT AVG(bill) FROM Customers -- it tells average bill of all customers
SELETC MAX(bill) FROM Customers  -- it tells who made maximum bill among the customers
SELECT MIN(bill) FROM Customers -- it tells who made  minimum bill among the customers

--for these also we can add features  where the city is chennai

                  -- INNER JOIN
SELECT Customers.name , Orders.item
FROM Customers;
INNER JOIN Orders
ON Custmores.Customer_id = Orders.Customer_id;
-- it joins only if match records of FROM  table with INNER JOIN TABLE then it show output but if not found it will not show 
-- like if the from table having customer_id 1 but in orders there is no customer_id in the sense it will not show both the details 

                  -- LEFT JOIN
SELECT Customers.name , Orders.item
FROM Customers
LEFT JOIN Orders
ON Customers.Customer_id = Orders.Customer_id;
-- It joins  when the records existing in the customers 
-- if the records does not exists in the orders then it will return null in the customer_id


                  -- RIGHT JOIN

SELECT Customers.name , ORDERS.item
FROM Customers
LEFT JOIN Orders
ON Customers.Customer_id = Orders.Customer_id;
-- it joins when the records existing in the Orders;
-- if the records does not exist in the orders then it will returnnull in the customer_id
    

                 -- FULL OUTER JOIN
SELECT Customers.name, Orders.item
FROM Customers
FULL OUTER JOIN Orders
ON Customers.customer_id = Orders.Customer_id;
-- it join when the record exist in the customers table and does not exist in the orders table and return if the orders table does not conatians record as NULL
-- it join when the record exist in the orders table and does not exist in the customers table and return if the customer table does not contains record as NULL
-- it join when the record exist both the tables 


                 --CELL

CELL -- it gives up value 
     -- like if the answer is 11.23 then it will give upper value  12

                -- FLOOR

FLOOR --it gives down vlaue
      -- like if the answer is 11.23 then it will give lower value 11

                 --ROUND

ROUND -- it gives nearest value
      -- like if the answer is 11.23 then it gives 11 and also if the answer 11.57 then it gives 12
      








